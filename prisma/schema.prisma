generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tasks    Task[]
  projects Project[] @relation("ProjectResponsible")
}

model Client {
  id        String   @id @default(cuid())
  name      String
  email     String?
  phone     String?
  company   String?
  document  String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projects Project[]
}

enum ProjectType {
  AVULSO
  RECORRENTE
}

enum ProjectStatus {
  COTACAO
  NEGOCIACAO
  ATIVO
  PAUSADO
  CONCLUIDO
  CANCELADO
}

model Project {
  id          String        @id @default(cuid())
  name        String
  clientId    String
  type        ProjectType
  status      ProjectStatus @default(COTACAO)
  description String?
  startDate   DateTime?
  endDate     DateTime?
  totalValue  Decimal?      @db.Decimal(12, 2)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  client           Client            @relation(fields: [clientId], references: [id], onDelete: Cascade)
  tasks            Task[]
  credentials      Credential[]
  notes            Note[]
  installments     Installment[]
  recurringCharges RecurringCharge[]
  expenses         Expense[]
  responsibleId    String?
  responsible      User?             @relation("ProjectResponsible", fields: [responsibleId], references: [id])

  @@index([clientId])
  @@index([responsibleId])
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model Task {
  id          String       @id @default(cuid())
  projectId   String
  title       String
  description String?
  status      TaskStatus   @default(TODO)
  priority    TaskPriority @default(MEDIUM)
  order       Int
  assigneeId  String?
  dueDate     DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  project  Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignee User?   @relation(fields: [assigneeId], references: [id])

  @@index([projectId])
  @@index([assigneeId])
}

model Credential {
  id        String   @id @default(cuid())
  projectId String
  platform  String
  url       String?
  username  String
  password  String
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model Note {
  id        String   @id @default(cuid())
  projectId String
  title     String
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

enum PaymentStatus {
  PENDENTE
  PAGO
  CANCELADO
}

model Installment {
  id        String        @id @default(cuid())
  projectId String
  number    Int
  value     Decimal       @db.Decimal(12, 2)
  dueDate   DateTime
  paidAt    DateTime?
  status    PaymentStatus @default(PENDENTE)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model RecurringCharge {
  id             String        @id @default(cuid())
  projectId      String
  description    String
  value          Decimal       @db.Decimal(12, 2)
  referenceMonth DateTime
  dueDate        DateTime
  paidAt         DateTime?
  status         PaymentStatus @default(PENDENTE)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model Expense {
  id          String    @id @default(cuid())
  description String
  value       Decimal   @db.Decimal(12, 2)
  date        DateTime
  dueDate     DateTime?
  status      String    @default("PENDENTE")
  paidAt      DateTime?
  categoryId  String
  projectId   String?
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  category ExpenseCategory @relation(fields: [categoryId], references: [id])
  project  Project?        @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([categoryId])
  @@index([projectId])
  @@index([status])
}

model ExpenseCategory {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())

  expenses Expense[]
}
